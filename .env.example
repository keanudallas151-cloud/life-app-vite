# Firebase configuration for the current auth/cloud data path.
# Copy to .env.local (preferred) or .env for local development.
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Optional public support contact used by the v0.7.1 communication template pack.
NEXT_PUBLIC_SUPPORT_EMAIL=life.customer.support@gmail.com

# Canonical public site origin. Vercel preview hosts should redirect back to this
# production URL so Google authentication stays on the same approved domain.
NEXT_PUBLIC_SITE_URL=https://life-ten-green.vercel.app

# ─── Stripe subscriptions (server-side) ───
# Create a Stripe account, set the currency to AUD, and create two recurring
# products: Basic (A$14.99/month) and Premium (A$49.99/month). Copy the price
# IDs from the Stripe dashboard into the variables below.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_BASIC_PRICE_ID=price_xxx_basic
STRIPE_PREMIUM_PRICE_ID=price_xxx_premium
# Optional, exposed to the client if needed for Stripe.js. Not currently used by
# the redirect-based Checkout flow.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── Firebase Admin (server-side, for Stripe webhook → Firestore writes) ───
# Provide ONE of the following:
# 1. The full service-account JSON, single-line:
FIREBASE_SERVICE_ACCOUNT_JSON=
# 2. OR the three split fields below (replace literal newlines in the private
#    key with the string \n):
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
