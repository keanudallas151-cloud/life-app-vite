# Local-only Supabase client configuration
# Copy to .env.local (preferred) or .env for local development.
# Get these from: https://supabase.com/dashboard/project/_/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Optional canonical site origin used when auth emails are generated outside
# the active browser session. Leave unset for local-only development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
