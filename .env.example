# Firebase configuration for the current auth/cloud data path.
# Copy to .env.local (preferred) or .env for local development.
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Optional public support contact used by the v0.7.1 communication template pack.
NEXT_PUBLIC_SUPPORT_EMAIL=life.customer.support@gmail.com

# Canonical public site origin. Vercel preview hosts should redirect back to this
# production URL so Google authentication stays on the same approved domain.
NEXT_PUBLIC_SITE_URL=https://life-ten-green.vercel.app
