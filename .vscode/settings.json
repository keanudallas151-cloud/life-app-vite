{
  "github.codespaces.defaultExtensions": [
    "GitHub.codespaces",
    "GitHub.vscode-pull-request-github",
    "Github.copilot",
    "github.copilot-chat",
    "dbaeumer.vscode-eslint",
    "eamodio.gitlens",
    "github.vscode-github-actions",
    "gruntfuggly.todo-tree",
    "ms-azuretools.vscode-azure-github-copilot",
    "ms-azuretools.vscode-azure-mcp-server",
    "mtxr.sqltools",
    "ms-ossdata.vscode-pgsql",
    "phu1237.vs-browser",
    "usernamehw.errorlens",
  ],
  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.copilotMemory.enabled": true,
  "github.copilot.chat.gpt54ConcisePrompt.enabled": true,
  "github.copilot.chat.agent.omitFileAttachmentContents": true,
  "github.copilot.chat.githubMcpServer.enabled": true,
  "chat.mcp.autostart": true,
  "chat.mcp.apps.enabled": true,
  "terminal.integrated.initialHint.copilotCli": true,
  "terminal.integrated.defaultProfile.linux": "bash",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
  },
  "eslint.validate": ["javascript", "javascriptreact"],
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "always",
  "todo-tree.tree.showCountsInTree": true,
  "todo-tree.regex.regex": "(//|#|<!--|;|/\\*|\\*)\\s*(TODO|FIXME|NOTE|IDEA)\\b",
  "mediaPreview.video.loop": true,
  "workbench.externalBrowser": "chrome",
  "github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,
  "cSpell.words": ["Firestore"],
  "editor.tokenColorCustomizations": {
    "comments": "",
    "textMateRules": [],
  },
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true,
  },
  "github.copilot.chat.githubMcpServer.enabled": true,
  "chat.mcp.assisted.nuget.enabled": true,
}
